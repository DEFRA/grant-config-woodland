{
  "name": "grant-config-woodland",
  "version": "0.0.2",
  "description": "Grant config for woodland grant",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DEFRA/grant-config-woodland.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky install",
    "github:release": "npx cdp-github-release grant-config-woodland",
    "publish:changed": "changeset publish",
    "version:changed": "changeset version",
    "version": "changeset"
  },
  "author": "Defra Future-Grants-Framework Team",
  "license": "OGL-UK-3.0",
  "devDependencies": {
    "@changesets/changelog-github": "0.5.1",
    "@changesets/cli": "2.29.6",
    "husky": "9.1.7"
  },
  "release-it": {
    "npm": {
      "publish": false
    },
    "github": {
      "release": true,
      "releaseName": "${version}",
      "releaseNotes": "echo ''"
    },
    "git": {
      "commitMessage": "Tagged grant-config-woodland ${version}",
      "tagName": "${version}",
      "requireCleanWorkingDir": false,
      "commitArgs": [
        "--no-verify"
      ]
    }
  },
  "bin": {
    "cdp-github-release": "ci/release-it.sh"
  }
}
